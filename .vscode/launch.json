{
  "version": "0.2.0",
  "configurations": [
    
    {
      "name": "Flutter (.env)",
      "type": "dart",
      "request": "launch",
      "program": "lib/main.dart",
      "cwd": "${workspaceFolder}",
      "flutterMode": "debug",
      "toolArgs": [
        "--dart-define-from-file=.env"
      ]
    }
  ]
}
